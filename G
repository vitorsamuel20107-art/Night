local PlayerDrawings = {} local Bones = { {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"}, {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"} }
local function CreateDrawingsForPlayer(player) if not PlayerDrawings[player] then PlayerDrawings[player] = { Line = Drawing.new("Line"), Box = Drawing.new("Square"), Health = Drawing.new("Line"), SkelLines = {}, SkelCircle = Drawing.new("Circle") } for i = 1, #Bones do local line = Drawing.new("Line") line.Visible = false line.Thickness = 1.5 line.Transparency = 1 PlayerDrawings[player].SkelLines[i] = line end local c = PlayerDrawings[player].SkelCircle c.Visible = false c.Thickness = 1.5 c.Transparency = 1 c.Filled = false end end
local function RemoveDrawingsForPlayer(player) if PlayerDrawings[player] then PlayerDrawings[player].Line:Remove() PlayerDrawings[player].Box:Remove() PlayerDrawings[player].Health:Remove() for _, line in pairs(PlayerDrawings[player].SkelLines) do line:Remove() end PlayerDrawings[player].SkelCircle:Remove() PlayerDrawings[player] = nil end end
Players.PlayerAdded:Connect(CreateDrawingsForPlayer) Players.PlayerRemoving:Connect(RemoveDrawingsForPlayer) for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateDrawingsForPlayer(p) end end
local function IsEnemy(player) if player == LocalPlayer then return false end if player.Team ~= nil and LocalPlayer.Team ~= nil then return player.Team ~= LocalPlayer.Team end local myTeam = LocalPlayer:GetAttribute("Team") local eTeam = player:GetAttribute("Team") if myTeam ~= nil and eTeam ~= nil then return myTeam ~= eTeam end return true end
local function IsAlive(player) if not player or not player.Character then return false end local hum = player.Character:FindFirstChildOfClass("Humanoid") return hum and hum.Health > 0 and player.Character:FindFirstChild("HumanoidRootPart") end
local function GetDynamicTargetPart(character) if Aimbot_Settings.PullPart == "Head" then return character:FindFirstChild("Head") or character:FindFirstChild("head") or character:FindFirstChild("HumanoidRootPart") else return character:FindFirstChild(Aimbot_Settings.PullPart) or character:FindFirstChild("HumanoidRootPart") end end
local function IsPartVisible(targetPart) if not Aimbot_Settings.VisibleCheck then return true end local origin = Camera.CFrame.Position GlobalRayParams.FilterDescendantsInstances = {LocalPlayer.Character, targetPart.Parent} return workspace:Raycast(origin, targetPart.Position - origin, GlobalRayParams) == nil end
local function ApplyChams(character) if not character then return end local hl = character:FindFirstChild("NIGHT_Chams") or Instance.new("Highlight") hl.Name = "NIGHT_Chams" local targetColor = ESP_Settings.RainbowChams and Current_Rainbow_Color or ESP_Settings.ChamsColor hl.FillColor = targetColor hl.OutlineColor = targetColor hl.FillTransparency = 0.5 hl.OutlineTransparency = 0.1 hl.Enabled = true if hl.Parent ~= character then hl.Parent = character end end

local lastTimeStats = os.clock() local frames = 0
RunService.RenderStepped:Connect(function()
    frames = frames + 1 local currentTime = os.clock() if currentTime - lastTimeStats >= 1 then FPSText.Text = "FPS: " .. math.floor(frames) frames = 0 lastTimeStats = currentTime end
    pcall(function() PingText.Text = string.format("Ping: %d ms", LocalPlayer:GetNetworkPing() * 1000) end)
    if FunctionsEnabled and ESP_Settings.RainbowChams then Current_Rainbow_H = (Current_Rainbow_H + (task.wait() * Rainbow_Speed)) % 1 Current_Rainbow_Color = Color3.fromHSV(Current_Rainbow_H, 1, 1) end
    local localIsAlive = IsAlive(LocalPlayer) local isChamsActive = ESP_Settings.Boxes and ESP_Settings.BoxType == "Chams Glow" local shouldDrawSkeleton = ESP_Settings.Skeleton and not isChamsActive
    
    for player, drawings in pairs(PlayerDrawings) do
        local isTargetAlive = IsAlive(player)
        if FunctionsEnabled and localIsAlive and isTargetAlive and IsEnemy(player) then
            local char = player.Character local hrp = char.HumanoidRootPart local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position) local distance = (hrp.Position - Camera.CFrame.Position).Magnitude local highlight = char:FindFirstChild("NIGHT_Chams")
            if onScreen and distance <= ESP_Settings.MaxDistance then
                drawings.Line.Visible = ESP_Settings.Lines drawings.Line.From = Vector2.new(Camera.ViewportSize.X / 2, (ESP_Settings.LineOrigin == "Cima") and 0 or Camera.ViewportSize.Y) drawings.Line.To = Vector2.new(pos.X, pos.Y) drawings.Line.Color = CurrentTheme drawings.Line.Thickness = 1
                if ESP_Settings.Boxes then if ESP_Settings.BoxType == "Quadrado" then drawings.Box.Visible = true local sizeX, sizeY = 2000 / pos.Z, 2500 / pos.Z drawings.Box.Size = Vector2.new(sizeX, sizeY) drawings.Box.Position = Vector2.new(pos.X - sizeX / 2, pos.Y - sizeY / 2) drawings.Box.Color = CurrentTheme drawings.Box.Thickness = 1 drawings.Box.Filled = false if highlight then highlight.Enabled = false end elseif ESP_Settings.BoxType == "Chams Glow" then drawings.Box.Visible = false ApplyChams(char) end else drawings.Box.Visible = false if highlight then highlight.Enabled = false end end
                local hum = char:FindFirstChildOfClass("Humanoid") if hum and ESP_Settings.Health then drawings.Health.Visible = true local hpPercent = math.clamp(hum.Health / hum.MaxHealth, 0, 1) local sizeY, sizeX = 2500 / pos.Z, 2000 / pos.Z local barHeight = sizeY * hpPercent local offset = (sizeX / 2) + 4 drawings.Health.From = Vector2.new(pos.X - offset, pos.Y + (sizeY / 2)) drawings.Health.To = Vector2.new(pos.X - offset, pos.Y + (sizeY / 2) - barHeight) drawings.Health.Color = hpPercent >= 0.7 and Color3.fromRGB(0, 255, 0) or (hpPercent >= 0.4 and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(255, 0, 0)) drawings.Health.Thickness = 2 else drawings.Health.Visible = false end
                if shouldDrawSkeleton then for i, bone in ipairs(Bones) do local p1, p2 = char:FindFirstChild(bone[1]), char:FindFirstChild(bone[2]) if p1 and p2 then local pos1, on1 = Camera:WorldToViewportPoint(p1.Position) local pos2, on2 = Camera:WorldToViewportPoint(p2.Position) if on1 and on2 then drawings.SkelLines[i].Visible = true drawings.SkelLines[i].From = Vector2.new(pos1.X, pos1.Y) drawings.SkelLines[i].To = Vector2.new(pos2.X, pos2.Y) drawings.SkelLines[i].Color = CurrentTheme else drawings.SkelLines[i].Visible = false end else drawings.SkelLines[i].Visible = false end end local head = char:FindFirstChild("Head") if head then local hPos, hOn = Camera:WorldToViewportPoint(head.Position) if hOn then drawings.SkelCircle.Visible = true drawings.SkelCircle.Position = Vector2.new(hPos.X, hPos.Y) local fovFactor = math.tan(math.rad(Camera.FieldOfView) / 2) local virtualHeadSize = 0.8 local calculatedRadius = (Camera.ViewportSize.Y / (2 * hPos.Z * fovFactor)) * virtualHeadSize drawings.SkelCircle.Radius = math.clamp(calculatedRadius, 1, 200) drawings.SkelCircle.Color = CurrentTheme else drawings.SkelCircle.Visible = false end else drawings.SkelCircle.Visible = false end else for _, l in pairs(drawings.SkelLines) do l.Visible = false end drawings.SkelCircle.Visible = false end
            else
                drawings.Line.Visible = false drawings.Box.Visible = false drawings.Health.Visible = false for _, l in pairs(drawings.SkelLines) do l.Visible = false end drawings.SkelCircle.Visible = false if highlight then highlight.Enabled = false end
            end
        else
            drawings.Line.Visible = false drawings.Box.Visible = false drawings.Health.Visible = false for _, l in pairs(drawings.SkelLines) do l.Visible = false end drawings.SkelCircle.Visible = false if player.Character then local hl = player.Character:FindFirstChild("NIGHT_Chams") if hl then hl.Enabled = false end end
        end
    end
end)

local function GetClosestEnemyTarget() local closestDist = math.huge local closestPart = nil local center = Camera.ViewportSize / 2 local fovRadius = Aimbot_Settings.FovSize / 2 for _, player in ipairs(Players:GetPlayers()) do if IsEnemy(player) and IsAlive(player) then local targetPart = GetDynamicTargetPart(player.Character) if targetPart then local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position) if onScreen then local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude if dist <= fovRadius and dist < closestDist then if IsPartVisible(targetPart) then closestDist = dist closestPart = targetPart end end end end end end return closestPart end
RunService:BindToRenderStep("NIGHT_Aimbot_Priority", Enum.RenderPriority.Camera.Value - 1, function() pcall(function() if FunctionsEnabled and Aimbot_Settings.Mode ~= "Nenhum" and IsAlive(LocalPlayer) then local canAim = (Aimbot_Settings.Type == "Ao Olhar") or (Aimbot_Settings.Type == "Ao Atirar" and IsTouchingScreen) if canAim then if LockedTarget and (not LockedTarget.Parent or not IsAlive(Players:GetPlayerFromCharacter(LockedTarget.Parent.Parent or LockedTarget.Parent))) then LockedTarget = nil end if not LockedTarget then LockedTarget = GetClosestEnemyTarget() end if LockedTarget then if not IsPartVisible(LockedTarget) then LockedTarget = nil return end local targetPos = LockedTarget.Position local dist = (targetPos - Camera.CFrame.Position).Magnitude local velocity = LockedTarget.AssemblyLinearVelocity or Vector3.new(0, 0, 0) if Aimbot_Settings.PullPart == "Head" and dist > 80 then targetPos = targetPos - Vector3.new(0, 0.4, 0) end local predictedPos = targetPos + (velocity * math.clamp(dist / 1000, 0, 0.2)) local pos, onS = Camera:WorldToViewportPoint(predictedPos) if (Vector2.new(pos.X, pos.Y) - Camera.ViewportSize/2).Magnitude > (Aimbot_Settings.FovSize / 2) then LockedTarget = nil return end Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, predictedPos), Aimbot_Settings.Mode == "Rage" and 0.85 or 0.15) end else LockedTarget = nil end else LockedTarget = nil end end) end)

local OriginalHeadData = {}
RunService.Heartbeat:Connect(function() if FunctionsEnabled and HitboxEnabled then for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character then local h = p.Character:FindFirstChild("Head") if h and IsEnemy(p) and IsAlive(p) then if not OriginalHeadData[p] or OriginalHeadData[p].Part ~= h then OriginalHeadData[p] = { Part = h, Size = h.Size, Transparency = h.Transparency, Massless = h.Massless, CanCollide = h.CanCollide } end h.Size = Vector3.new(2.1, 2.1, 2.1) h.Transparency = 0.7 h.Massless = true h.CanCollide = false end end end else for p, data in pairs(OriginalHeadData) do if data.Part and data.Part.Parent then data.Part.Size = data.Size data.Part.Transparency = data.Transparency data.Part.Massless = data.Massless data.Part.CanCollide = data.CanCollide end end table.clear(OriginalHeadData) end end)
Players.PlayerRemoving:Connect(function(player) OriginalHeadData[player] = nil SaveConfig() end)
