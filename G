                        drawings.Box.Size = Vector2.new(sizeX, sizeY) drawings.Box.Position = Vector2.new(pos.X - sizeX / 2, pos.Y - sizeY / 2) 
                        drawings.Box.Color = CurrentTheme drawings.Box.Thickness = 1 drawings.Box.Filled = false 
                        if highlight then highlight:Destroy() end 
                    elseif ESP_Settings.BoxType == "Chams Glow" then
                        drawings.Box.Visible = false ApplyChams(char)
                    end
                else drawings.Box.Visible = false if highlight then highlight:Destroy() end end
                
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum and ESP_Settings.Health then
                    drawings.Health.Visible = true local hpPercent = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                    local sizeY, sizeX = 2500 / pos.Z, 2000 / pos.Z local barHeight = sizeY * hpPercent local offset = (sizeX / 2) + 4
                    drawings.Health.From = Vector2.new(pos.X - offset, pos.Y + (sizeY / 2)) 
                    drawings.Health.To = Vector2.new(pos.X - offset, pos.Y + (sizeY / 2) - barHeight) 
                    drawings.Health.Color = hpPercent >= 0.7 and Color3.fromRGB(0, 255, 0) or (hpPercent >= 0.4 and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(255, 0, 0))
                    drawings.Health.Thickness = 2
                else drawings.Health.Visible = false end

                if shouldDrawSkeleton then
                    for i, bone in ipairs(Bones) do
                        local p1, p2 = char:FindFirstChild(bone[1]), char:FindFirstChild(bone[2])
                        if p1 and p2 then
                            local pos1, on1 = Camera:WorldToViewportPoint(p1.Position) local pos2, on2 = Camera:WorldToViewportPoint(p2.Position)
                            if on1 and on2 then drawings.SkelLines[i].Visible = true drawings.SkelLines[i].From = Vector2.new(pos1.X, pos1.Y) drawings.SkelLines[i].To = Vector2.new(pos2.X, pos2.Y) drawings.SkelLines[i].Color = CurrentTheme else drawings.SkelLines[i].Visible = false end
                        else drawings.SkelLines[i].Visible = false end
                    end
                    local head = char:FindFirstChild("Head")
                    if head then
                        local hPos, hOn = Camera:WorldToViewportPoint(head.Position)
                        if hOn then
                            drawings.SkelCircle.Visible = true drawings.SkelCircle.Position = Vector2.new(hPos.X, hPos.Y)
                            local fovFactor = math.tan(math.rad(Camera.FieldOfView) / 2) local virtualHeadSize = 0.8
                            local calculatedRadius = (Camera.ViewportSize.Y / (2 * hPos.Z * fovFactor)) * virtualHeadSize
                            drawings.SkelCircle.Radius = math.clamp(calculatedRadius, 1, 200) drawings.SkelCircle.Color = CurrentTheme
                        else drawings.SkelCircle.Visible = false end
                    else drawings.SkelCircle.Visible = false end
                else
                    for _, l in pairs(drawings.SkelLines) do l.Visible = false end drawings.SkelCircle.Visible = false
                end
            else
                drawings.Line.Visible = false drawings.Box.Visible = false drawings.Health.Visible = false
                for _, l in pairs(drawings.SkelLines) do l.Visible = false end drawings.SkelCircle.Visible = false
                if highlight then highlight:Destroy() end
            end
        else
            drawings.Line.Visible = false drawings.Box.Visible = false drawings.Health.Visible = false
            for _, l in pairs(drawings.SkelLines) do l.Visible = false end drawings.SkelCircle.Visible = false
            if player.Character then local hl = player.Character:FindFirstChild("NIGHT_Chams") if hl then hl:Destroy() end end
        end
    end
end)

local function GetClosestEnemyTarget()
    local closestDist = math.huge local closestPart = nil local center = Camera.ViewportSize / 2 local fovRadius = Aimbot_Settings.FovSize / 2
    for _, player in ipairs(Players:GetPlayers()) do
        if IsEnemy(player) and IsAlive(player) then
            local targetPart = GetDynamicTargetPart(player.Character)
            if targetPart then
                local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist <= fovRadius and dist < closestDist then
                        if IsPartVisible(targetPart) then closestDist = dist closestPart = targetPart end
                    end
                end
            end
        end
    end
    return closestPart
end

RunService:BindToRenderStep("NIGHT_Aimbot_Priority", Enum.RenderPriority.Camera.Value - 1, function()
    pcall(function()
        if FunctionsEnabled and Aimbot_Settings.Mode ~= "Nenhum" and IsAlive(LocalPlayer) then
            local canAim = (Aimbot_Settings.Type == "Ao Olhar") or (Aimbot_Settings.Type == "Ao Atirar" and IsTouchingScreen)
            if canAim then
                if LockedTarget and (not LockedTarget.Parent or not IsAlive(Players:GetPlayerFromCharacter(LockedTarget.Parent.Parent or LockedTarget.Parent))) then LockedTarget = nil end
                if not LockedTarget then LockedTarget = GetClosestEnemyTarget() end

                if LockedTarget then
                    if not IsPartVisible(LockedTarget) then LockedTarget = nil return end
                    local targetPos = LockedTarget.Position local dist = (targetPos - Camera.CFrame.Position).Magnitude
                    local velocity = LockedTarget.AssemblyLinearVelocity or Vector3.new(0, 0, 0)
                    if Aimbot_Settings.PullPart == "Head" and dist > 80 then targetPos = targetPos - Vector3.new(0, 0.4, 0) end

                    local predictedPos = targetPos + (velocity * (dist / 1000))
                    local pos, onS = Camera:WorldToViewportPoint(predictedPos)
                    if (Vector2.new(pos.X, pos.Y) - Camera.ViewportSize/2).Magnitude > (Aimbot_Settings.FovSize / 2) then LockedTarget = nil return end

                    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, predictedPos), Aimbot_Settings.Mode == "Rage" and 0.85 or 0.15)
                end
            else LockedTarget = nil end
        else LockedTarget = nil end
    end)
end)

