            RunService:BindToRenderStep("NIGHT_Aimbot_Priority", Enum.RenderPriority.Camera.Value - 1, function()
                local ok, err = pcall(function() 
                    if FunctionsEnabled and Aimbot_Settings.Mode ~= "Nenhum" and IsAlive(LocalPlayer) then
                        local canAim = (Aimbot_Settings.Type == "Ao Olhar") or (Aimbot_Settings.Type == "Ao Atirar" and IsTouchingScreen)
                        if canAim then
                            if LockedTarget and (not LockedTarget.Parent or not IsAlive(Players:GetPlayerFromCharacter(LockedTarget.Parent.Parent or LockedTarget.Parent))) then LockedTarget = nil end
                            if not LockedTarget then LockedTarget = GetClosestEnemyTarget() end
                            if LockedTarget then
                                if not IsPartVisible(LockedTarget) then LockedTarget = nil return end
                                local targetPos = LockedTarget.Position
                                local dist = (targetPos - Camera.CFrame.Position).Magnitude
                                if dist < 0.5 then LockedTarget = nil return end
                                local velocity = LockedTarget.AssemblyLinearVelocity or Vector3.new(0, 0, 0)
                                if Aimbot_Settings.PullPart == "Head" and dist > 80 then targetPos = targetPos - Vector3.new(0, 0.4, 0) end
                                local predictedPos = targetPos + (velocity * (dist / 1000))
                                local pos, onS = Camera:WorldToViewportPoint(predictedPos)
                                if (Vector2.new(pos.X, pos.Y) - Camera.ViewportSize/2).Magnitude > ((tonumber(Aimbot_Settings.FovSize) or 0) / 2) then LockedTarget = nil return end
                                local smoothBase = Aimbot_Settings.Mode == "Rage" and 0.85 or 0.15
                                local distanceFactor = math.clamp(1 - (dist / 1000), 0.5, 1) 
                                local smoothFinal = smoothBase * distanceFactor
                                Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, predictedPos), smoothFinal)
                            end
                        else LockedTarget = nil end
                    else LockedTarget = nil end
                end)
                if not ok then SalvarNoDiario("Erro Loop RenderStep Aimbot: " .. tostring(err), "ERROR") end
            end)
        end)

        task.spawn(function()
            local HitboxCache = {} 
            local function IsEnemy(p) if p == LocalPlayer then return false end if p.Team ~= nil and LocalPlayer.Team ~= nil then return p.Team ~= LocalPlayer.Team end local m = LocalPlayer:GetAttribute("Team") local e = p:GetAttribute("Team") if m ~= nil and e ~= nil then return m ~= e end return true end
            RunService.Heartbeat:Connect(function()
                local ok, err = pcall(function() 
                    if FunctionsEnabled and HitboxEnabled then
                        for _, p in pairs(Players:GetPlayers()) do 
                            if p ~= LocalPlayer and IsEnemy(p) and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                                local head = p.Character:FindFirstChild("Head")
                                if head then if not HitboxCache[p] then HitboxCache[p] = head.Size end head.Size = Vector3.new(2.1, 2.1, 2.1) head.Transparency = 0.7 head.CanCollide = true end
                            else if HitboxCache[p] and p.Character and p.Character:FindFirstChild("Head") then p.Character.Head.Size = HitboxCache[p] p.Character.Head.Transparency = 0 HitboxCache[p] = nil end end 
                        end
                    else for p, os in pairs(HitboxCache) do if p and p.Character and p.Character:FindFirstChild("Head") then p.Character.Head.Size = os p.Character.Head.Transparency = 0 end end table.clear(HitboxCache) end
                end)
                if not ok then SalvarNoDiario("Erro Loop Heartbeat Hitbox: " .. tostring(err), "ERROR") end
            end)
        end)
    end

    IniciarPainel()
end)

if not ExecucaoSegura then
    SalvarNoDiario("FALHA FATAL NA INICIALIZAÇÃO: " .. tostring(ErroFatal), "ERROR")
end
