CreateSimpleRadioGroup(TabAimbot, "Tipo de Aimbot:", 0, 155, {"Ao Olhar", "Ao Atirar"}, "Ao Olhar", function(v) 
    Aimbot_Settings.Type = v 
    if v == "Ao Atirar" then 
        -- Mantém os botões do menu visíveis como elemento estético
        TriggerUIFrame.Visible = true 
        TriggerCircle.Visible = false -- Círculo flutuante ocultado para não atrapalhar
        VisibleCheckBtn:TweenPosition(UDim2.new(0, 0, 0, 255), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.25, true) 
    else 
        TriggerCircle.Visible = false 
        IsTouchingScreen = false 
        VisibleCheckBtn:TweenPosition(UDim2.new(0, 0, 0, 215), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.25, true) 
        task.delay(0.15, function() 
            if Aimbot_Settings.Type == "Ao Olhar" then 
                TriggerUIFrame.Visible = false 
            end 
        end) 
    end 
end)
