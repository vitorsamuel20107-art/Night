local function CreateCheckbox(parent, text, x, y, defaultOn, action)
    local btn = Instance.new("TextButton", parent) btn.Size = UDim2.new(0, 180, 0, 25) btn.Position = UDim2.new(0, x, 0, y) btn.BackgroundTransparency = 1 btn.Text = ""
    local box = Instance.new("Frame", btn) box.Size = UDim2.new(0, 25, 0, 25) box.BackgroundColor3 = defaultOn and CurrentTheme or C_DARK_GREY Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)  
    local checkmark = Instance.new("TextLabel", box) checkmark.Size = UDim2.new(1, 0, 1, 0) checkmark.BackgroundTransparency = 1 checkmark.Text = "✓" checkmark.TextColor3 = C_WHITE checkmark.Visible = defaultOn  
    local label = Instance.new("TextLabel", btn) label.Size = UDim2.new(1, -35, 1, 0) label.Position = UDim2.new(0, 35, 0, 0) label.BackgroundTransparency = 1 label.Text = text label.TextColor3 = C_WHITE label.Font = Enum.Font.GothamBold label.TextSize = 14 label.TextXAlignment = Enum.TextXAlignment.Left  
    table.insert(ThemeCallbacks, function(color) if checkmark.Visible then box.BackgroundColor3 = color end end)
    btn.MouseButton1Click:Connect(function() checkmark.Visible = not checkmark.Visible box.BackgroundColor3 = checkmark.Visible and CurrentTheme or C_DARK_GREY if action then action(checkmark.Visible) end end) return btn
end

