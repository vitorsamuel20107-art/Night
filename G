-- ================== LÓGICA DE APLICAÇÃO E CACHE DE SKINS ==================
local function CacheAndApplySurface(part, skinName, targetSkinKey, srcSideOrPartName)
    if not part:FindFirstChild("NIGHT_Cache") then
        local cacheFolder = Instance.new("Folder")
        cacheFolder.Name = "NIGHT_Cache"
        cacheFolder.Parent = part
        local origSA = part:FindFirstChildOfClass("SurfaceAppearance")
        if origSA then
            origSA:Clone().Parent = cacheFolder
        end
    end

    for _, child in ipairs(part:GetChildren()) do
        if child:IsA("SurfaceAppearance") then
            child:Destroy()
        end
    end

    if skinName ~= "Padrão" then
        local skinFolder = SkinsFolder:FindFirstChild(targetSkinKey)
        local skinType = skinFolder and skinFolder:FindFirstChild(skinName)
        local srcFolder = skinType and skinType:FindFirstChild("Camera") and skinType.Camera:FindFirstChild(WEAR)
        if srcFolder and srcFolder:FindFirstChild(srcSideOrPartName) then
            local clone = srcFolder[srcSideOrPartName]:Clone()
            clone.Name = "SurfaceAppearance"
            clone.Parent = part
        end
    else
        local cacheFolder = part:FindFirstChild("NIGHT_Cache")
        if cacheFolder then
            local origSA = cacheFolder:FindFirstChildOfClass("SurfaceAppearance")
            if origSA then
                local clone = origSA:Clone()
                clone.Name = "SurfaceAppearance"
                clone.Parent = part
            end
        end
    end
end

local function applyWeaponSkin(model, forceDefault)
    if not model or not SC_isAlive() then return end
    
    local isKnife = (model.Name == "T Knife" or model.Name == "CT Knife" or knivesData[model.Name])
    local targetSkinKey = isKnife and selectedKnife or model.Name
    
    local isEnabled = SkinChangerEnabled and not forceDefault
    
    pcall(function()
        local left, right = model:FindFirstChild("Left Arm"), model:FindFirstChild("Right Arm")
        if left or right then
            local gloveSkinName = isEnabled and (SelectedSkins[GLOVES_KEY] or "Padrão") or "Padrão"
            
            for _, side in ipairs({"Left Arm", "Right Arm"}) do
                local arm = model:FindFirstChild(side)
                if arm then
                    local gloveMesh = arm:FindFirstChild("Glove")
                    if gloveMesh then
                        CacheAndApplySurface(gloveMesh, gloveSkinName, GLOVES_KEY, side)
                    end
                end
            end
        end

        if model.Name ~= GLOVES_KEY and model:FindFirstChild("Weapon") then
            local skinName = isEnabled and (SelectedSkins[targetSkinKey] or "Padrão") or "Padrão"
            local weaponFolder = model:FindFirstChild("Weapon")

            for _, part in ipairs(weaponFolder:GetDescendants()) do
                if part:IsA("BasePart") then
                    CacheAndApplySurface(part, skinName, targetSkinKey, part.Name)
                end
            end
            model:SetAttribute("SkinApplied", skinName)
        end
    end)
end

Camera.ChildAdded:Connect(function(obj)
    if not SkinChangerEnabled or not SC_isAlive() then return end
    task.wait(COOLDOWN)
    applyWeaponSkin(obj, false)
end)

