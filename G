local draggingCircle, dragStartCircle, startPosCircle
TriggerCircle.InputBegan:Connect(function(input) if not Trigger_Settings.Locked and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then draggingCircle = true dragStartCircle = input.Position startPosCircle = TriggerCircle.Position end end)
UserInputService.InputChanged:Connect(function(input) if draggingCircle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStartCircle TriggerCircle.Position = UDim2.new(startPosCircle.X.Scale, startPosCircle.X.Offset + delta.X, startPosCircle.Y.Scale, startPosCircle.Y.Offset + delta.Y) end end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingCircle = false SaveTriggerPosition() end end)

local function IsInTriggerCircle(pos) if Aimbot_Settings.Type ~= "Ao Atirar" then return false end local absPos = TriggerCircle.AbsolutePosition local absSize = TriggerCircle.AbsoluteSize local center = Vector2.new(absPos.X + absSize.X/2, absPos.Y + absSize.Y/2) return (Vector2.new(pos.X, pos.Y) - center).Magnitude <= Trigger_Settings.Radius end
UserInputService.TouchStarted:Connect(function(touch, gpe) if Aimbot_Settings.Type == "Ao Atirar" and IsInTriggerCircle(touch.Position) then IsTouchingScreen = true TriggerCircle.BackgroundColor3 = Color3.fromRGB(0, 255, 100) end end)
UserInputService.TouchEnded:Connect(function(touch, gpe) if Aimbot_Settings.Type == "Ao Atirar" then IsTouchingScreen = false TriggerCircle.BackgroundColor3 = Trigger_Settings.Locked and Color3.fromRGB(100, 100, 100) or Color3.fromRGB(255, 0, 0) end end)
UserInputService.InputBegan:Connect(function(i, gpe) if not gpe and i.UserInputType == Enum.UserInputType.MouseButton1 then if Aimbot_Settings.Type == "Ao Atirar" and IsInTriggerCircle(i.Position) then IsTouchingScreen = true TriggerCircle.BackgroundColor3 = Color3.fromRGB(0, 255, 100) end end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 and Aimbot_Settings.Type == "Ao Atirar" then IsTouchingScreen = false TriggerCircle.BackgroundColor3 = Trigger_Settings.Locked and Color3.fromRGB(100, 100, 100) or Color3.fromRGB(255, 0, 0) end end)

