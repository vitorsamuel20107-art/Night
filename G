local function PlayMinimizeAnimation()
    CurrentUIState = "Minimized"
    local tOut = TweenService:Create(MainScale, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 0})
    tOut:Play()
    tOut.Completed:Wait()
    MainFrame.Visible = false
    OpenButton.Visible = true
    OpenScale.Scale = 0
    TweenService:Create(OpenScale, TweenInfo.new(animSpeed, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
end

local function PlayMaximizeAnimation()
    CurrentUIState = "Open"
    local tOut = TweenService:Create(OpenScale, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Scale = 0})
    tOut:Play()
    tOut.Completed:Wait()
    OpenButton.Visible = false
    MainFrame.Visible = true
    MainScale.Scale = 0
    TweenService:Create(MainScale, TweenInfo.new(animSpeed, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
end

local function OpenFromHidden()
    CurrentUIState = "Open"
