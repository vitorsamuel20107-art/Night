local PlayerDrawings = {}
local Bones = { {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"}, {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"} }

local function CreateDrawingsForPlayer(player)
    if not PlayerDrawings[player] then 
        PlayerDrawings[player] = { Line = Drawing.new("Line"), Box = Drawing.new("Square"), Health = Drawing.new("Line"), SkelLines = {}, SkelCircle = Drawing.new("Circle") } 
        for i = 1, #Bones do local line = Drawing.new("Line") line.Visible = false line.Thickness = 1.5 line.Transparency = 1 PlayerDrawings[player].SkelLines[i] = line end
        local c = PlayerDrawings[player].SkelCircle c.Visible = false c.Thickness = 1.5 c.Transparency = 1 c.Filled = false
    end
end

local function RemoveDrawingsForPlayer(player)
    if PlayerDrawings[player] then 
        PlayerDrawings[player].Line:Remove() PlayerDrawings[player].Box:Remove() PlayerDrawings[player].Health:Remove() 
        for _, line in pairs(PlayerDrawings[player].SkelLines) do line:Remove() end
        PlayerDrawings[player].SkelCircle:Remove() PlayerDrawings[player] = nil 
    end
end

Players.PlayerAdded:Connect(CreateDrawingsForPlayer) Players.PlayerRemoving:Connect(RemoveDrawingsForPlayer)
for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateDrawingsForPlayer(p) end end

local function IsEnemy(player)
    if player == LocalPlayer then return false end
    if player.Team ~= nil and LocalPlayer.Team ~= nil then return player.Team ~= LocalPlayer.Team end
    local myTeam = LocalPlayer:GetAttribute("Team") local eTeam = player:GetAttribute("Team")
    if myTeam ~= nil and eTeam ~= nil then return myTeam ~= eTeam end
    return true
end

local function IsAlive(player)
    if not player or not player.Character then return false end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0 and player.Character:FindFirstChild("HumanoidRootPart")
end

local function GetDynamicTargetPart(character)
    if Aimbot_Settings.PullPart == "Head" then return character:FindFirstChild("Head") or character:FindFirstChild("head") or character:FindFirstChild("HumanoidRootPart")
    else return character:FindFirstChild(Aimbot_Settings.PullPart) or character:FindFirstChild("HumanoidRootPart") end
end

local function IsPartVisible(targetPart)
    if not Aimbot_Settings.VisibleCheck then return true end
    local origin = Camera.CFrame.Position
    GlobalRayParams.FilterDescendantsInstances = {LocalPlayer.Character, targetPart.Parent}
    local hit = workspace:Raycast(origin, targetPart.Position - origin, GlobalRayParams)
    return hit == nil
end

local function ApplyChams(character)
    if not character then return end
    local hl = character:FindFirstChild("NIGHT_Chams") or Instance.new("Highlight") hl.Name = "NIGHT_Chams"
    local targetColor = ESP_Settings.RainbowChams and Current_Rainbow_Color or ESP_Settings.ChamsColor
    hl.FillColor = targetColor hl.OutlineColor = targetColor hl.FillTransparency = 0.5 hl.OutlineTransparency = 0.1
    if hl.Parent ~= character then hl.Parent = character end
end

local lastTimeStats = os.clock()
local frames = 0

