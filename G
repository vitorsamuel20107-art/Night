local function SaveTriggerPosition() pcall(function() if makefolder and not isfolder(ConfigFolder) then makefolder(ConfigFolder) end if writefile then local data = { XScale = TriggerCircle.Position.X.Scale, XOffset = TriggerCircle.Position.X.Offset, YScale = TriggerCircle.Position.Y.Scale, YOffset = TriggerCircle.Position.Y.Offset } writefile(ConfigFile, HttpService:JSONEncode(data)) end end) end
