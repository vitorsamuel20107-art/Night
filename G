local folderName = "Logs_Teste"
local logFileName = folderName .. "/bloxstrike_3rdperson_simple_back.txt"

if makefolder then pcall(function() makefolder(folderName) end) end

local function salvarLog(tipo, message)
    local timestamp = os.date("%Y-%m-%d %H:%M:%S")
    local formatoLog = string.format("[%s] [%s]: %s\n", timestamp, tipo:upper(), message)
    if writefile then
        local conteudoAtual = ""
        pcall(function() conteudoAtual = readfile(logFileName) end)
        pcall(function() writefile(logFileName, conteudoAtual .. formatoLog) end)
    else 
        print(formatoLog) 
    end
end

