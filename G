local function CreateCheckbox(parent, text, x, y, configKey, action)
    local state = NIGHT_Config[configKey] if state == nil then state = false end
    local btn = Instance.new("TextButton", parent) btn.Size = UDim2.new(0, 180, 0, 25) btn.Position = UDim2.new(0, x, 0, y) btn.BackgroundTransparency = 1 btn.Text = ""
    local box = Instance.new("Frame", btn) box.Size = UDim2.new(0, 25, 0, 25) box.BackgroundColor3 = state and CurrentTheme or C_DARK_GREY Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)  
    local checkmark = Instance.new("TextLabel", box) checkmark.Size = UDim2.new(1, 0, 1, 0) checkmark.BackgroundTransparency = 1 checkmark.Text = "✓" checkmark.TextColor3 = C_WHITE checkmark.Visible = state  
    local label = Instance.new("TextLabel", btn) label.Size = UDim2.new(1, -35, 1, 0) label.Position = UDim2.new(0, 35, 0, 0) label.BackgroundTransparency = 1 label.Text = text label.TextColor3 = C_WHITE label.Font = Enum.Font.GothamBold label.TextSize = 14 label.TextXAlignment = Enum.TextXAlignment.Left  
    table.insert(ThemeCallbacks, function(color) if checkmark.Visible then box.BackgroundColor3 = color end end)
    
    local function fire(v) NIGHT_Config[configKey] = v SaveConfig() if action then action(v) end end
    
    -- Função interna para forçar estado de fora sem causar loops
    local function setState(v, triggerAction)
        checkmark.Visible = v
        box.BackgroundColor3 = v and CurrentTheme or C_DARK_GREY
        NIGHT_Config[configKey] = v
        SaveConfig()
        if triggerAction and action then action(v) end
    end
    
    btn.MouseButton1Click:Connect(function() 
        setState(not checkmark.Visible, true) 
    end)
    
    task.spawn(function() fire(state) end) 
    return btn, setState
end

local function CreateSlider(parent, label, configKey, maxVal, x, y, action)
    local state = NIGHT_Config[configKey] or (maxVal / 2)
    local container = Instance.new("Frame", parent) container.Size = UDim2.new(0, 230, 0, 25) container.Position = UDim2.new(0, x, 0, y) container.BackgroundColor3 = C_DARK_GREY Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6)
    local fill = Instance.new("Frame", container) fill.Size = UDim2.new(math.clamp(state/maxVal, 0, 1), 0, 1, 0) fill.BackgroundColor3 = CurrentTheme Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 6) table.insert(ThemeCallbacks, function(color) fill.BackgroundColor3 = color end)
    local valText = Instance.new("TextLabel", container) valText.Size = UDim2.new(1, 0, 1, 0) valText.BackgroundTransparency = 1 valText.Text = string.format("%.1f", state) valText.TextColor3 = C_WHITE  
    
    local draggingSlider = false 
    local function UpdateSlider(input) 
        local pos = math.clamp((input.Position.X - container.AbsolutePosition.X) / container.AbsoluteSize.X, 0, 1) 
        fill.Size = UDim2.new(pos, 0, 1, 0) local realVal = pos * maxVal valText.Text = string.format("%.1f", realVal)
        NIGHT_Config[configKey] = realVal SaveConfig() if action then action(realVal) end 
    end  
    container.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then draggingSlider = true UpdateSlider(i) end end) 
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then draggingSlider = false end end) 
    UserInputService.InputChanged:Connect(function(i) if draggingSlider and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then UpdateSlider(i) end end)
    task.spawn(function() if action then action(state) end end)
end

