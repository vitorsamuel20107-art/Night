UserInputService.InputChanged:Connect(function(input)
    if arrastandoSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local posReal = input.Position.X - SliderTrack.AbsolutePosition.X
        local porcentagem = math.clamp(posReal / SliderTrack.AbsoluteSize.X, 0, 1)
        SliderScroller.Position = UDim2.new(porcentagem, -7, 0.5, -6)
        DISTANCIA_TRAS = MIN_ZOOM + (porcentagem * (MAX_ZOOM - MIN_ZOOM))
        SliderText.Text = string.format("ZOOM: %.1f", DISTANCIA_TRAS)
    end
end)

UserInputService.InputEnded:Connect(function(i) 
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then 
        arrastandoSlider = false 
    end 
end)

