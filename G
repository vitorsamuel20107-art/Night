-- Configurações da Câmera
local DISTANCIA_TRAS = 7.0     
local ALTURA_CIMA = 1.5        
local MIN_ZOOM, MAX_ZOOM = 2.0, 20.0
local VELOCIDADE_FREECAM = 1.2 

-- Estados Globais
_G.TerceiraPessoaAtiva = false 
_G.FreeCamAtiva = false

local conexaoLoopCam = nil
local posicaoFreeCam = Vector3.new(0, 0, 0)
local direcoesVoo = {frente = 0, tras = 0, esquerda = 0, direita = 0, cima = 0, baixo = 0}
local backupCameraViewmodel = {}

-- =============================================================================
-- FUNÇÕES DE UTILIDADE E SEGURANÇA
-- =============================================================================
local function obterHumanoidSeguro()
    local char = LocalPlayer.Character
    if char then return char:FindFirstChildOfClass("Humanoid") end
    return nil
end

local function obterRootSeguro()
    local char = LocalPlayer.Character
    local hum = obterHumanoidSeguro()
    if char and hum and hum.Health > 0 then
        return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChildWhichIsA("Part")
    end
    return nil
end

local function alternarControlesNativos(ativar)
    local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if playerGui then
        local touchGui = playerGui:FindFirstChild("TouchGui")
        if touchGui then
            touchGui.Enabled = ativar
        end
    end
end

local function restaurarVisibilidade()
    Camera.CameraType = Enum.CameraType.Custom
    alternarControlesNativos(true)
    
    local hum = obterHumanoidSeguro()
    if hum then hum.PlatformStand = false end
    
    -- Restaura os braços e armas da primeira pessoa
    for part, trans in pairs(backupCameraViewmodel) do 
        if part and part.Parent then 
            part.Transparency = trans 
        end 
    end
    table.clear(backupCameraViewmodel)
    
    -- Restaura a visibilidade do próprio corpo
    local char = LocalPlayer.Character
    if char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.LocalTransparencyModifier = 1 
            end
        end
    end
end

-- =============================================================================
-- LÓGICA PRINCIPAL DA CÂMERA
-- =============================================================================
local function gerenciarCamera()
    if conexaoLoopCam then 
        conexaoLoopCam:Disconnect() 
        conexaoLoopCam = nil 
    end
    
    if not _G.TerceiraPessoaAtiva and not _G.FreeCamAtiva then
        restaurarVisibilidade()
        return
    end
    
    Camera.CameraType = Enum.CameraType.Scriptable
    
    local root = obterRootSeguro()
    if root and _G.FreeCamAtiva then
        posicaoFreeCam = root.Position + Vector3.new(0, ALTURA_CIMA, 0)
    end

    conexaoLoopCam = RunService.RenderStepped:Connect(function()
        local char = LocalPlayer.Character
        local rootPart = obterRootSeguro()
        local hum = obterHumanoidSeguro()
        
        -- Esconde o viewmodel (braços/armas atrelados à câmera)
        for _, obj in pairs(Camera:GetChildren()) do
            if obj:IsA("Model") or obj:IsA("BasePart") then
                local parts = obj:IsA("BasePart") and {obj} or obj:GetDescendants()
                for i = 1, #parts do 
                    local p = parts[i]
                    if p:IsA("BasePart") then
                        if not backupCameraViewmodel[p] then 
                            backupCameraViewmodel[p] = p.Transparency 
                        end
                        p.Transparency = 1
                    end
                end
            end
        end

        -- Garante que o personagem esteja visível (LocalTransparencyModifier)
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") and not part.Name:find("Collision") and not part.Name:find("Hitbox") and part.Name ~= "HumanoidRootPart" then
                    part.LocalTransparencyModifier = 0 
                end
            end
        end

        local direcaoOlhar = Camera.CFrame.LookVector
        local direcaoLado = Camera.CFrame.RightVector

        -- MODO FREECAM
        if _G.FreeCamAtiva then
            if hum then hum.PlatformStand = true end 
            
            local movimento = Vector3.new(0, 0, 0)
            movimento = movimento + (direcaoOlhar * (direcoesVoo.frente - direcoesVoo.tras))
            movimento = movimento + (direcaoLado * (direcoesVoo.direita - direcoesVoo.esquerda))
            movimento = movimento + (Vector3.new(0, 1, 0) * (direcoesVoo.cima - direcoesVoo.baixo))
            
            if movimento.Magnitude > 0 then
                posicaoFreeCam = posicaoFreeCam + (movimento.Unit * VELOCIDADE_FREECAM)
            end
            
            Camera.CFrame = CFrame.lookAt(posicaoFreeCam, posicaoFreeCam + direcaoOlhar)
            
        -- MODO 3ª PESSOA
        elseif _G.TerceiraPessoaAtiva and rootPart and char then
            if hum then hum.PlatformStand = false end
            local posicaoFoco = rootPart.Position + Vector3.new(0, ALTURA_CIMA, 0)
            local novaPosicaoCamera = posicaoFoco - (direcaoOlhar * DISTANCIA_TRAS)
            Camera.CFrame = CFrame.lookAt(novaPosicaoCamera, novaPosicaoCamera + direcaoOlhar)
        else
            Camera.CameraType = Enum.CameraType.Custom
        end
    end)
end

